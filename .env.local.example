# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Storage base URL (derived from your Supabase URL)
# Format: https://your-project-id.supabase.co/storage/v1/object/public
NEXT_PUBLIC_SUPABASE_STORAGE_URL=your_supabase_storage_url

# Admin panel password — set a strong password here
ADMIN_PASSWORD=your_secure_admin_password
